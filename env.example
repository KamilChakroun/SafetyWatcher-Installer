# ================================================================
#  .env.dev — development environment
#
#  Copy to .env before running:
#    cp .env.dev .env
#
#  Camera URLs in mongo_cam should use host.docker.internal:
#    e.g. rtsp://host.docker.internal:8554/stream1
#  Update them with:
#    db.cameras.updateMany(
#      { url: /^rtsp:\/\/127\.0\.0\.1/ },
#      [{ $set: { url: { $replaceAll: {
#        input: "$url", find: "127.0.0.1",
#        replacement: "host.docker.internal"
#      }}}}]
#    )
# ================================================================

# Frontend
VITE_WS_URL=ws://localhost/ws

STREAMER_URLS=ws://streamer:9000

# Auth
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# CORS
ALLOWED_ORIGINS=http://localhost

# Metrics endpoint auth token (leave empty to disable auth)
METRICS_TOKEN=

# Camera database
MONGO_CAM_DB=surveillance
MONGO_CAM_COLL=cameras

# Reader — frames published to NATS per second
READER_FPS=2

# MinIO — object storage for detection frame images
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=safety-watcher-history
# Must be reachable by the browser (host IP or domain, NOT the Docker service name)
MINIO_PRESIGN_ENDPOINT=localhost:9000

# Detection event grouping window in seconds
# Frames from the same camera within this window belong to the same event
EVENT_WINDOW_SECONDS=120
