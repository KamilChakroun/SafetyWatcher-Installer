{
  "title": "Safety Watcher \u2014 Overview",
  "uid": "safety-watcher-overview",
  "tags": [
    "safety-watcher"
  ],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "type": "row",
      "title": "\ud83d\udd25 Service Health",
      "id": 100,
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 1,
      "title": "Gateway \u2014 UP/DOWN",
      "type": "stat",
      "gridPos": {
        "x": 0,
        "y": 1,
        "w": 4,
        "h": 3
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green"
                },
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "up{job=\"gateway\"}",
          "legendFormat": "Gateway",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 2,
      "title": "cAdvisor \u2014 UP/DOWN",
      "type": "stat",
      "gridPos": {
        "x": 4,
        "y": 1,
        "w": 4,
        "h": 3
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green"
                },
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "up{job=\"cadvisor\"}",
          "legendFormat": "cAdvisor",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 3,
      "title": "NATS \u2014 UP/DOWN",
      "type": "stat",
      "gridPos": {
        "x": 8,
        "y": 1,
        "w": 4,
        "h": 3
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green"
                },
                "0": {
                  "text": "DOWN",
                  "color": "red"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "up{job=\"nats\"}",
          "legendFormat": "NATS",
          "instant": true,
          "range": false
        }
      ]
    },
    {
      "id": 4,
      "title": "Container Restart Count (last 1h)",
      "type": "stat",
      "gridPos": {
        "x": 12,
        "y": 1,
        "w": 6,
        "h": 3
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "background",
        "orientation": "horizontal"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 3
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "increase(container_start_time_seconds{name=~\"(gateway|Reader|Inference|Streamer|safety-watcher-.*)\"}[1h])",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Gateway \u2014 Requests/sec",
      "type": "stat",
      "gridPos": {
        "x": 18,
        "y": 1,
        "w": 6,
        "h": 3
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum(rate(http_requests_total{job=\"gateway\"}[1m]))",
          "legendFormat": "req/s"
        }
      ]
    },
    {
      "type": "row",
      "title": "\ud83d\udcca Container Resources",
      "id": 101,
      "gridPos": {
        "x": 0,
        "y": 4,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 10,
      "title": "CPU Usage % per Container",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "rate(container_cpu_usage_seconds_total{name=~\"(safety-watcher-gateway-1|safety-watcher-frontend-1|safety-watcher-usermanager-1|safety-watcher-cammanager-1|Reader|Inference|Streamer|nats)\"}[1m]) * 100",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Memory Usage (MB) per Container",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 5,
        "w": 12,
        "h": 8
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "container_memory_usage_bytes{name=~\"(safety-watcher-gateway-1|safety-watcher-frontend-1|safety-watcher-usermanager-1|safety-watcher-cammanager-1|Reader|Inference|Streamer|nats)\"} / 1024 / 1024",
          "legendFormat": "{{name}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "\ud83c\udf10 Gateway API Metrics",
      "id": 102,
      "gridPos": {
        "x": 0,
        "y": 13,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 20,
      "title": "Request Rate by Endpoint",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum by (handler) (rate(http_requests_total{job=\"gateway\"}[1m]))",
          "legendFormat": "{{handler}}"
        }
      ]
    },
    {
      "id": 21,
      "title": "Request Latency p95 (ms)",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "histogram_quantile(0.95, sum by (handler, le) (rate(http_request_duration_seconds_bucket{job=\"gateway\"}[5m]))) * 1000",
          "legendFormat": "p95 {{handler}}"
        }
      ]
    },
    {
      "id": 22,
      "title": "Error Rate (4xx/5xx)",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 22,
        "w": 12,
        "h": 6
      },
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": {
            "lineWidth": 2
          },
          "color": {
            "fixedColor": "red",
            "mode": "fixed"
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "sum by (handler) (rate(http_requests_total{job=\"gateway\",status=~\"4..|5..\"}[1m]))",
          "legendFormat": "errors {{handler}}"
        }
      ]
    },
    {
      "type": "row",
      "title": "\ud83d\udce8 NATS Message Throughput",
      "id": 103,
      "gridPos": {
        "x": 0,
        "y": 28,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 30,
      "title": "Messages In/sec",
      "type": "timeseries",
      "gridPos": {
        "x": 0,
        "y": 29,
        "w": 12,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "mps",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "rate(gnatsd_varz_in_msgs[1m])",
          "legendFormat": "msgs in/s"
        }
      ]
    },
    {
      "id": 31,
      "title": "Bytes In/sec",
      "type": "timeseries",
      "gridPos": {
        "x": 12,
        "y": 29,
        "w": 12,
        "h": 6
      },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "PBFA97CFB590B2093"
          },
          "expr": "rate(gnatsd_varz_in_bytes[1m])",
          "legendFormat": "bytes in/s"
        }
      ]
    },
    {
      "type": "row",
      "title": "\ud83d\udccb Container Logs",
      "id": 104,
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 1
      },
      "collapsed": false
    },
    {
      "id": 40,
      "title": "All Container Logs",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 36,
        "w": 24,
        "h": 10
      },
      "options": {
        "showTime": true,
        "showLabels": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none",
        "wrapLogMessage": false
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "P8E80F9AEF21F6940"
          },
          "expr": "{service=~\"reader|gateway|streamer|inference|cammanager|usermanager|mongo_cam|mongo_user|nats|frontend|prometheus|loki|promtail|cadvisor\"}",
          "legendFormat": ""
        }
      ]
    },
    {
      "id": 41,
      "title": "App Warnings & Errors",
      "type": "logs",
      "gridPos": {
        "x": 0,
        "y": 46,
        "w": 24,
        "h": 8
      },
      "options": {
        "showTime": true,
        "showLabels": true,
        "sortOrder": "Descending"
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "P8E80F9AEF21F6940"
          },
          "expr": "{service=~\"reader|streamer|inference\"} |~ \"ERROR|WARN\"",
          "legendFormat": ""
        }
      ]
    }
  ],
